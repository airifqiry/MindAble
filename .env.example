ANTHROPIC_API_KEY=your_anthropic_api_key_here

SECRET_KEY=your-secret-key-here
DB_PASSWORD=your-password-here

# HTTPS to job boards (Himalayas, RemoteOK, etc.): install certifi (see requirements.txt).
# Only if you still see SSL: CERTIFICATE_VERIFY_FAILED after pip install -r requirements.txt:
# MINDABLE_INSECURE_SSL=1

# Sentence-transformers (default: all-MiniLM-L6-v2, 384-d). First run downloads the model.
# MINDABLE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Bump to force re-embedding all stored vectors after model or embedding code changes:
# MINDABLE_EMBEDDING_VERSION=st-v1